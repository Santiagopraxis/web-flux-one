  <!-- SECCIÓN 6: POR QUÉ ELEGIR fluX -->
  <section class="section-light" id="por-que">
    <style>
      /* Estilos Premium para las Tarjetas Interactivas (Trigger Popup) */
      .clickable-card {
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(15, 23, 42, 0.08) !important;
        background: #ffffff !important;
        display: flex;
        flex-direction: column;
        text-align: left;
      }
      .clickable-card:hover {
        transform: translateY(-5px);
        border-color: rgba(0, 184, 148, 0.3) !important;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.04);
      }
      .clickable-card .card-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
      }
      .clickable-card .toggle-indicator {
        font-size: 1.1rem;
        color: #64748B;
        transition: transform 0.4s ease, color 0.4s ease;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #F1F5F9;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .clickable-card:hover .toggle-indicator {
        color: #00B894;
        background: rgba(0, 184, 148, 0.08);
        transform: scale(1.1);
      }

      /* Estilos Premium del Modal / Popup */
      .flux-modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s ease;
      }
      .flux-modal-overlay.active {
        opacity: 1;
        pointer-events: auto;
      }

      /* Modal Card */
      .flux-modal-card {
        background: #ffffff;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 28px;
        width: 90%;
        max-width: 680px;
        padding: 40px;
        box-shadow: 0 30px 60px rgba(15, 23, 42, 0.15);
        position: relative;
        transform: translateY(30px) scale(0.96);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        text-align: left;
        box-sizing: border-box;
      }
      .flux-modal-overlay.active .flux-modal-card {
        transform: translateY(0) scale(1);
      }

      /* Close Button */
      .flux-modal-close {
        position: absolute;
        top: 24px; right: 24px;
        background: #F1F5F9;
        border: none;
        border-radius: 50%;
        width: 36px; height: 36px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; color: #64748B;
        cursor: pointer;
        transition: all 0.3s;
        z-index: 10;
      }
      .flux-modal-close:hover {
        background: #E2E8F0;
        color: #0F172A;
        transform: rotate(90deg);
      }

      /* Modal Typography */
      .flux-modal-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #0F172A;
        margin-top: 0;
        margin-bottom: 8px;
        letter-spacing: -0.02em;
        text-align: left;
      }
      .flux-modal-subtitle {
        font-size: 0.95rem;
        color: #64748B;
        margin-top: 0;
        margin-bottom: 28px;
        line-height: 1.5;
        text-align: left;
      }

      /* Comparison Columns */
      .flux-modal-comparison {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 28px;
      }
      @media (max-width: 600px) {
        .flux-modal-comparison {
          grid-template-columns: 1fr;
          gap: 16px;
        }
      }
      .comparison-col {
        padding: 16px;
        border-radius: 12px;
        text-align: left;
      }
      .comparison-col.traditional {
        background: rgba(239, 68, 68, 0.02);
        border: 1px solid rgba(239, 68, 68, 0.08);
      }
      .comparison-col.traditional h4 {
        color: #EF4444;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 0;
        margin-bottom: 8px;
      }
      .comparison-col.traditional p {
        color: #64748B;
        font-size: 0.85rem;
        line-height: 1.5;
        margin: 0;
      }
      .comparison-col.flux-way {
        background: rgba(0, 184, 148, 0.02);
        border: 1px solid rgba(0, 184, 148, 0.1);
      }
      .comparison-col.flux-way h4 {
        color: #00B894;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 0;
        margin-bottom: 8px;
      }
      .comparison-col.flux-way p {
        color: #0F172A;
        font-size: 0.85rem;
        line-height: 1.5;
        margin: 0;
      }

      /* Speed Widget */
      .flux-speed-widget {
        background: #F8FAFC;
        border: 1px solid #E2E8F0;
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 28px;
        box-sizing: border-box;
      }
      .flux-speed-widget .widget-title {
        font-size: 0.8rem;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 0;
        margin-bottom: 20px;
        text-align: left;
      }
      .speed-track {
        margin-bottom: 20px;
        text-align: left;
      }
      .speed-track:last-child {
        margin-bottom: 0;
      }
      .speed-track .track-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #334155;
        margin-bottom: 8px;
      }
      .speed-track .track-bar-container {
        height: 8px;
        background: #E2E8F0;
        border-radius: 100px;
        overflow: hidden;
        position: relative;
      }
      .speed-track .track-bar {
        height: 100%;
        width: 0;
        border-radius: 100px;
        transition: width 0.1s linear;
      }
      .speed-track.traditional .track-bar {
        background: #EF4444;
      }
      .speed-track.flux-way .track-bar {
        background: #00B894;
        box-shadow: 0 0 10px rgba(0, 184, 148, 0.4);
      }
      .speed-track .track-status {
        font-size: 0.75rem;
        font-weight: 500;
        margin-top: 6px;
        height: 16px;
      }
      .speed-track.traditional .track-status {
        color: #94A3B8;
      }
      .speed-track.flux-way .track-status {
        color: #00B894;
        font-weight: 600;
      }

      /* Call to Action Question */
      .easier-question {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        background: linear-gradient(90deg, rgba(0, 184, 148, 0.06) 0%, rgba(37, 99, 235, 0.03) 100%);
        border-radius: 100px;
        border: 1px solid rgba(0, 184, 148, 0.15);
        box-sizing: border-box;
      }
      .easier-question span.q-badge {
        font-size: 0.7rem;
        font-weight: 700;
        color: #00B894;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        flex-shrink: 0;
      }
      .easier-question p.q-text {
        font-size: 0.85rem;
        color: #334155;
        font-weight: 600;
        margin: 0;
        text-align: left;
      }
    </style>

