          <div class="showcase-browser-frame">
            <div class="browser-topbar">
              <div class="browser-dot red"></div>
              <div class="browser-dot yellow"></div>
              <div class="browser-dot green"></div>
              <span class="browser-title">fluX One — Dashboard Ejecutivo</span>
            </div>
            <div class="browser-content">
              <!-- PANTALLA RECAUDO -->
              <div class="dashboard-view active" id="db-view-recaudo">
                <video src="../assets/videos/co/recaudos.mp4" autoplay muted playsinline class="showcase-video"></video>
              </div>
              <!-- PANTALLA DISPERSIÓN -->
              <div class="dashboard-view" id="db-view-dispersion">
                <video src="../assets/videos/co/dispersiones.mp4" autoplay muted playsinline class="showcase-video"></video>
              </div>
              <!-- PANTALLA INTELIGENCIA -->
              <div class="dashboard-view" id="db-view-inteligencia">
                <video src="../assets/videos/co/bi.mp4" autoplay muted playsinline class="showcase-video"></video>
              </div>
            </div>
          </div>
        </div>
      </div>

    <!-- Script Inline para alternar pestañas del Dashboard -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.showcase-tab').forEach(tab => {
          tab.addEventListener('click', () => {
            const target = tab.getAttribute('data-target');
            
            // Desactivar pestañas anteriores
            document.querySelectorAll('.showcase-tab').forEach(t => t.classList.remove('active'));
            // Activar pestaña cliqueada
            tab.classList.add('active');
            
            // Mover dashboard en Desktop
            document.querySelectorAll('.showcase-dashboard-col .dashboard-view').forEach(view => {
              view.classList.remove('active');
            });
                        const desktopView = document.querySelector(`.showcase-dashboard-col #db-view-${target}`);
            if (desktopView) {
              desktopView.classList.add('active');
              const vid = desktopView.querySelector('video');
              if (vid) {
                vid.currentTime = 0;
                vid.play();
              }
            }
            
            // Mover dashboard en Móvil
            document.querySelectorAll('.showcase-mobile-dashboard-preview .dashboard-view').forEach(view => {
              view.classList.remove('active');
            });
            const mobileView = document.querySelector(`.showcase-tab[data-target="${target}"] #db-view-${target}-mobile`);
            if (mobileView) {
              mobileView.classList.add('active');
              const mvid = mobileView.querySelector('video');
              if (mvid) {
                mvid.currentTime = 0;
                mvid.play();
              }
            }
          });
        });
      });
    </script>
    </div>
  </section>

