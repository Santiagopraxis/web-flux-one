  <!-- SECCIÓN 4: NEXA — EL UNIVERSO EN TUS MANOS (STICKY SCROLL-JACK) -->
  <section class="section-light" id="para-quien" style="padding: 120px 0; overflow: visible; position: relative;">

    <style>
      /* Estilos específicos de Nexa Light Sticky Scroll */
      .nexa-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(0, 184, 148, 0.1);
        border: 1px solid rgba(0, 184, 148, 0.25);
        border-radius: 100px;
        padding: 6px 16px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #00B894;
        margin-bottom: 24px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      .nexa-eyebrow-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #00B894;
        animation: nexaPulse 2s ease-in-out infinite;
      }
      @keyframes nexaPulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.7); }
      }
      .nexa-cta {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 15px 32px;
        border-radius: 100px;
        background: linear-gradient(135deg, #00B894 0%, #2563EB 100%);
        color: white !important;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 8px 32px rgba(0, 184, 148, 0.25);
        text-decoration: none;
      }
      .nexa-cta:hover {
        transform: translateY(-3px);
        box-shadow: 0 16px 48px rgba(0, 184, 148, 0.35);
      }

      /* Estilos específicos y refinados de las Scroll Cards en White Background */
      .scroll-card.card.glass {
        background: rgba(248, 250, 252, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(15, 23, 42, 0.05);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.01), inset 0 1px 0 rgba(255, 255, 255, 0.8);
        transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        transform: scale(0.96);
        opacity: 0.25;
      }
      .scroll-card.card.glass.active {
        opacity: 1;
        transform: scale(1.02);
        background: #ffffff;
        border-color: rgba(0, 184, 148, 0.25);
        box-shadow: 0 24px 60px rgba(0, 184, 148, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.9);
      }
      .scroll-card-accent {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, #00B894, #2563EB);
        opacity: 0;
        transition: opacity 0.5s ease;
      }
      .scroll-card.card.glass.active .scroll-card-accent {
        opacity: 1;
      }

      /* Optimizaciones de espacio y alineación */
      #para-quien .sticky-wrapper {
        gap: 40px;
      }
      #para-quien .sticky-left {
        width: 42%;
        padding-right: 24px;
      }
      #para-quien .scrolling-right {
        width: 58%;
      }
      
      @media (max-width: 900px) {
        #para-quien .sticky-wrapper {
          flex-direction: column !important;
          gap: 24px !important;
        }
        #para-quien .sticky-left {
          width: 100% !important;
          padding-right: 0 !important;
          position: relative !important;
          text-align: center;
        }
        #para-quien .scrolling-right {
          width: 100% !important;
        }
        
        /* Ajustar subtitulo y cta para que se vean bien centrados */
        #para-quien .section-subtitle {
