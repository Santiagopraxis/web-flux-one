        <p class="flux-modal-subtitle">From collection to accounting reconciliation. No manual tasks, no errors.</p>
        
        <div class="flux-modal-comparison">
          <div class="comparison-col traditional">
            <h4>The traditional method</h4>
            <p>Conciliar a mano cada transferencia contra tu ERP, buscar facturas perdidas y perseguir soportes de pago de los clientes.</p>
          </div>
          <div class="comparison-col flux-way">
            <h4>The fluX effect</h4>
            <p>Orquestación automatizada: el cliente realiza el pago, el sistema lo concilia en tu ERP de inmediato en tiempo real y actualiza su estado.</p>
          </div>
        </div>

        <!-- Simulador de Velocidad / Animación de Automatización ERP -->
        <div class="flux-speed-widget" id="speed-automatizacion">
          <h4 class="widget-title">ERP Reconciliation Simulation</h4>
          <div class="speed-track traditional">
            <div class="track-label">Reconciliation Contable Manual</div>
            <div class="track-bar-container">
              <div class="track-bar traditional-progress" style="width:0%;"></div>
            </div>
            <div class="track-status traditional-status">Esperando soporte de pago...</div>
          </div>
          <div class="speed-track flux-way">
            <div class="track-label">Autoconciliación ERP fluX One</div>
            <div class="track-bar-container">
              <div class="track-bar flux-progress" style="width:0%;"></div>
            </div>
            <div class="track-status flux-status">Iniciando orquestación...</div>
          </div>
        </div>

        <div class="easier-question">
          <span class="q-badge">What if everything were easier?</span>
          <p class="q-text">Automatiza todo el flujo y elimina por completo los errores contables.</p>
        </div>
      </div>
    </div>

    <!-- JS MODAL & ANIMATION LOGIC -->
    <script>
      let activeTimers = [];

      function openFluxModal(modalId) {
        // Cerrar modales anteriores
        document.querySelectorAll('.flux-modal-overlay').forEach(m => m.classList.remove('active'));
        
        const modal = document.getElementById(modalId);
        if (modal) {
          modal.classList.add('active');
          document.body.style.overflow = 'hidden'; // Evitar scroll
          
          // Iniciar simulación de velocidad para este modal
          startSpeedSimulation(modalId);
        }
      }

      function closeFluxModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) {
          modal.classList.remove('active');
          document.body.style.overflow = ''; // Restaurar scroll
          
          // Detener y resetear simulación
          resetSpeedSimulation(modalId);
        }
      }

      function closeFluxModalOnOverlay(event, modalId) {
        if (event.target.id === modalId) {
          closeFluxModal(modalId);
        }
      }

      function startSpeedSimulation(modalId) {
        // Limpiar timers anteriores
        activeTimers.forEach(t => clearInterval(t));
        activeTimers = [];
        
        const widget = document.querySelector('#' + modalId + ' .flux-speed-widget');
        if (!widget) return;
        
        const tradProgress = widget.querySelector('.traditional-progress');
        const tradStatus = widget.querySelector('.traditional-status');
        const fluxProgress = widget.querySelector('.flux-progress');
        const fluxStatus = widget.querySelector('.flux-status');
        
        // Reset a cero
        tradProgress.style.width = '0%';
        fluxProgress.style.width = '0%';
        
        // --- 1. FLUX SIMULATION (HYPER-FAST) ---
        fluxStatus.innerHTML = 'Orquestando pago...';
        fluxStatus.style.color = '#00B894';
        
        setTimeout(() => {
          fluxProgress.style.width = '100%';
          fluxStatus.innerHTML = 'Collected and Reconciled in T+0! ✅';
          fluxStatus.style.fontWeight = 'bold';
        }, 300);

        // --- 2. TRADITIONAL SIMULATION (SUPER SLOW AND DISAPPOINTING) ---
        let currentTradPercent = 0;
        
        // Mensajes de paso a paso según el modal
        let steps = [];
        if (modalId === 'modal-pagos') {
          steps = [
            'Llamando al cliente para recordar pago...',
            'The customer promises to send voucher tomorrow...',
            'Waiting for bank transfer...',
            'Reviewing PDF payment voucher...',
            'Verifying voucher validity...',
            'Recording payment manually in system...',
            'Recovery completed (4-day delay) ❌'
          ];
        } else if (modalId === 'modal-tiempo-real') {
          steps = [
            'Waiting in line at physical payment point...',
            'Waiting to be served at the counter...',
            'Making physical payment...',
            'Waiting for bank clearance...',
            'Waiting 24 business hours...',
            'Waiting 48 business hours...',
            'Funds available (T+2 business days) ❌'
          ];
        } else if (modalId === 'modal-visibilidad') {
          steps = [
            'Downloading statement PDFs...',
            'Exporting bank movements to Excel...',
            'Searching for matching invoice for each payment...',
            'Identifying transfers with missing reference...',
            'Asking the team about phantom payments...',
            'Reconciling statements from previous month...',
            'Financial closing completed (T+30 days) ❌'
          ];
        } else {
          steps = [
            'Reviewing received bank transfers...',
            'Searching for customer\'s open invoices...',
            'Checking for penny discrepancies...',
            'Generating manual accounting entry...',
            'Updating status in the ERP...',
            'Notifying the accounts receivable team...',
            'Invoice manually self-reconciled (T+3 days) ❌'
          ];
        }

        tradStatus.innerHTML = steps[0];
        tradStatus.style.color = '#EF4444';
        
        const totalDuration = 7000; // 7 segundos de fila tradicional
        const intervalTime = 100;
        const totalIntervals = totalDuration / intervalTime;
        let elapsed = 0;
        
        const tradTimer = setInterval(() => {
          elapsed += intervalTime;
          currentTradPercent = Math.min((elapsed / totalDuration) * 100, 100);
          tradProgress.style.width = currentTradPercent + '%';
          
          // Cambiar mensaje según el porcentaje
          const stepIndex = Math.min(Math.floor((currentTradPercent / 100) * steps.length), steps.length - 1);
          tradStatus.innerHTML = steps[stepIndex];
          
          if (currentTradPercent >= 100) {
            clearInterval(tradTimer);
            tradStatus.style.fontWeight = 'bold';
          }
        }, intervalTime);
        
        activeTimers.push(tradTimer);
      }

      function resetSpeedSimulation(modalId) {
        activeTimers.forEach(t => clearInterval(t));
        activeTimers = [];
        
        const widget = document.querySelector('#' + modalId + ' .flux-speed-widget');
        if (!widget) return;
        
        widget.querySelector('.traditional-progress').style.width = '0%';
        widget.querySelector('.flux-progress').style.width = '0%';
        widget.querySelector('.traditional-status').innerHTML = 'Esperando soporte de pago...';
        widget.querySelector('.traditional-status').style.fontWeight = 'normal';
        widget.querySelector('.flux-status').innerHTML = 'Conectando...';
        widget.querySelector('.flux-status').style.fontWeight = 'normal';
      }
    </script>
  </section>

